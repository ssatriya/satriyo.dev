<script>
  import "fslightbox";

  declare var refreshFsLightbox: any;

  // fslightbox automatically detects elements with data-fslightbox on page load.
  // When using Astro View Transitions (ClientRouter), we need to refresh it after each page swap.
  document.addEventListener("astro:after-swap", () => {
    if (typeof refreshFsLightbox === 'function') {
      refreshFsLightbox();
    }
  });
</script>

